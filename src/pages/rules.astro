---
import * as fs from "fs";
import * as path from "path";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import type { LeagueConfig } from "../types/index.js";

const configPath = path.join(process.cwd(), "config", "league.json");
const config: LeagueConfig = JSON.parse(fs.readFileSync(configPath, "utf-8"));
const { currentYear } = config.league;
---

<Layout title={`Rules – ${config.league.name}`} years={[currentYear]} currentYear={currentYear}>
  <Header years={[currentYear]} currentYear={currentYear} leagueName={config.league.name} />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex-1">

    <!-- Page heading -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-green-900 mb-2">League Rules &amp; Format</h1>
      <p class="text-gray-500 text-sm">West GTA Clublink Men's Invitational — {currentYear} Season</p>
    </div>

    <!-- Welcome -->
    <section class="prose prose-green max-w-none mb-10 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <p class="text-gray-700 leading-relaxed">
        Welcome! As the first whiffs of freshly cut grass have started wafting in the air, I am sure we are all
        looking forward to hitting the courses. This year, let's put a different spin on things.
      </p>
      <p class="text-gray-700 leading-relaxed mt-3">
        The West GTA Clublink League Invitational will be a months-long event culminating in a 27-hole championship.
        <strong>This is NOT a Clublink sanctioned event.</strong>
      </p>
    </section>

    <!-- Season Play Rules -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-green-800 mb-4 flex items-center gap-2">
        <span class="inline-block w-1 h-6 bg-yellow-500 rounded"></span>
        Season Play Rules
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">

        <div>
          <h3 class="font-semibold text-gray-800 mb-2">Required Rounds (7 total)</h3>
          <p class="text-sm text-gray-600 mb-2">Each player must play and record a round at each of the following courses:</p>
          <ul class="space-y-1.5 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>Georgetown Golf Club</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>Blue Springs Golf Club</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>Glendale Golf Club</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>Greystone Golf Club</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>RattleSnake Point – Sidewinder</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>RattleSnake Point – Copperhead</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-yellow-600 font-semibold mt-0.5">1×</span>
              <span>Heron Point Golf Links</span>
            </li>
          </ul>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h3 class="font-semibold text-gray-800 mb-2">Bonus Rounds (top 3)</h3>
          <p class="text-sm text-gray-600 mb-2">
            After counting the best round from each required course, the next <strong>3 best rounds</strong> from
            any course also count towards your total. These bonus rounds can come from any of the required courses
            above <em>or</em> from the Glencairn courses below:
          </p>
          <ul class="space-y-1.5 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <span class="text-green-600 font-semibold mt-0.5">+</span>
              <span>Glencairn Golf Club – Leithfield-Speyside</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 font-semibold mt-0.5">+</span>
              <span>Glencairn Golf Club – Scotch Block-Leithfield</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-green-600 font-semibold mt-0.5">+</span>
              <span>Glencairn Golf Club – Speyside-Scotch Block</span>
            </li>
          </ul>
          <p class="text-xs text-gray-500 mt-2">
            No rounds are required at the Glencairn courses — they are only eligible for bonus scoring.
          </p>
        </div>

        <hr class="border-gray-100" />

        <ul class="space-y-2 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            All scores must be recorded in <strong>Golf Canada</strong> to count
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            <strong>Gross scores only</strong>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            Rounds from <strong>any tee</strong> are eligible — no tee requirement
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            Multiple scores can be submitted — only the <strong>best scores</strong> will count
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            All scores to be submitted to{" "}
            <a href="mailto:westgtaclinvitational@gmail.com" class="text-green-700 hover:underline font-medium">
              westgtaclinvitational@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-yellow-600 mt-0.5">⚠</span>
            All scores must be submitted <strong>before August 1st</strong> to count towards the championship
          </li>
        </ul>
      </div>
    </section>

    <!-- Championship -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-green-800 mb-4 flex items-center gap-2">
        <span class="inline-block w-1 h-6 bg-yellow-500 rounded"></span>
        Championship – August 3rd, 2026
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-6">

        <div>
          <p class="text-sm text-gray-700"><strong>Location:</strong> Glencairn Golf Club</p>
        </div>

        <div>
          <h3 class="font-semibold text-gray-800 mb-2">Team Seedings</h3>
          <p class="text-sm text-gray-600 mb-3">
            Teams of 4 golfers will be decided after season scoring is finished, based on the following seeding structure:
          </p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-green-800 text-white">
                  <th class="px-4 py-2 text-left font-semibold rounded-tl-lg">Team</th>
                  <th class="px-4 py-2 text-center font-semibold">Seed 1</th>
                  <th class="px-4 py-2 text-center font-semibold">Seed 2</th>
                  <th class="px-4 py-2 text-center font-semibold">Seed 3</th>
                  <th class="px-4 py-2 text-center font-semibold rounded-tr-lg">Seed 4</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {[
                  { team: "A", seeds: [1, 10, 11, 20] },
                  { team: "B", seeds: [2, 9, 12, 19] },
                  { team: "C", seeds: [3, 8, 13, 18] },
                  { team: "D", seeds: [4, 7, 14, 17] },
                  { team: "E", seeds: [5, 6, 15, 16] },
                ].map((row) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-2 font-semibold text-green-800">Team {row.team}</td>
                    {row.seeds.map((s) => (
                      <td class="px-4 py-2 text-center text-gray-700">{s}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <h3 class="font-semibold text-gray-800 mb-2">Championship Format – 27 Holes</h3>
          <p class="text-sm text-gray-600 mb-3">
            Once teams of 4 are made, teams must decide on pairings for the championship round.
            The championship includes 3 × 9-hole rounds:
          </p>
          <div class="space-y-2">
            {[
              { round: "Round 1", format: "9-Hole 2-Man Scramble" },
              { round: "Round 2", format: "9-Hole 2-Man Alternate Shot" },
              { round: "Round 3", format: "9-Hole 2-Man Better Ball (Handicapped)" },
            ].map((r) => (
              <div class="flex items-center gap-3 bg-green-50 rounded-lg px-4 py-3">
                <span class="text-xs font-semibold text-green-700 uppercase tracking-wide w-16 shrink-0">{r.round}</span>
                <span class="text-sm text-gray-800">{r.format}</span>
              </div>
            ))}
          </div>
          <p class="text-sm text-gray-600 mt-3">
            The <strong>champion team</strong> will be the lowest scoring team after all 27 holes.
          </p>
        </div>

      </div>
    </section>

    <!-- Entry Fees -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-green-800 mb-4 flex items-center gap-2">
        <span class="inline-block w-1 h-6 bg-yellow-500 rounded"></span>
        Entry Fees &amp; Prizes
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <p class="text-xs font-semibold text-yellow-700 uppercase tracking-wide mb-1">Entry Fee</p>
            <p class="text-2xl font-bold text-yellow-800">$100 <span class="text-sm font-normal">/ player</span></p>
            <p class="text-xs text-yellow-700 mt-1">Capped at 20 golfers</p>
          </div>
          <div class="bg-green-50 border border-green-200 rounded-lg p-4">
            <p class="text-xs font-semibold text-green-700 uppercase tracking-wide mb-1">1st Place Prize</p>
            <p class="text-2xl font-bold text-green-800">$1,000 <span class="text-sm font-normal">cash + shirts</span></p>
            <p class="text-xs text-green-700 mt-1">Winning team</p>
          </div>
        </div>

        <ul class="space-y-2 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            2nd place receives <strong>$400</strong>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-600 mt-0.5">✓</span>
            Additional prizes to be given out during the Championship
          </li>
          <li class="flex items-start gap-2">
            <span class="text-yellow-600 mt-0.5">⚠</span>
            Entry fee must be sent via <strong>e-transfer</strong> to{" "}
            <a href="mailto:westgtaclinvitational@gmail.com" class="text-green-700 hover:underline font-medium">
              westgtaclinvitational@gmail.com
            </a>{" "}
            before <strong>May 1st, 2026</strong>
          </li>
        </ul>

      </div>
    </section>

  </main>
</Layout>
