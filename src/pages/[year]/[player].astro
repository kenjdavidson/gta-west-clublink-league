---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { PlayerRounds } from "../../components/PlayerRounds";
import type { PlayerScore } from "../../types/index.js";
import { loadConfig, getConfiguredYears } from "../../utils/config-loader.js";
import { getYearlyScores } from "../../utils/score-service.js";
import { toSlug } from "../../utils/slug.js";

// ---------------------------------------------------------------------------
// Static paths — one path per (year, player) combination
// ---------------------------------------------------------------------------

export async function getStaticPaths() {
  const paths = [];
  for (const year of getConfiguredYears()) {
    const config = loadConfig(year);
    const scores = await getYearlyScores(year, config);
    for (const playerScore of scores.players) {
      paths.push({
        params: { year: String(year), player: toSlug(playerScore.member.name) },
        props: { player: playerScore },
      });
    }
  }
  return paths;
}

// ---------------------------------------------------------------------------
// Page data
// ---------------------------------------------------------------------------

const { year, player: playerSlug } = Astro.params;
const { player } = Astro.props as { player: PlayerScore };

const allYears = getConfiguredYears();
const config = loadConfig(Number(year));

// Re-use the cached result — score-service ensures no duplicate API calls
const yearlyScores = await getYearlyScores(Number(year), config);
---

<Layout title={`${player.member.name} – ${config.league.name} ${year}`} years={allYears} currentYear={Number(year)}>
  <Header years={allYears} currentYear={Number(year)} />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col-reverse gap-6 lg:flex-row">
      <!-- Left column: player list (navigation) -->
      <aside class="lg:w-44 lg:shrink-0">
        <h2
          class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 px-3"
        >
          Players
        </h2>
        <ul class="space-y-0.5">
          {
            yearlyScores.players.map((p) => {
              const slug = toSlug(p.member.name);
              const isActive = slug === playerSlug;
              return (
                <li>
                  <a
                    href={`${import.meta.env.BASE_URL}${year}/${slug}`}
                    class={`block px-3 py-2 text-sm rounded-lg transition-colors ${
                      isActive
                        ? "bg-green-700 text-white font-medium"
                        : "text-gray-700 hover:bg-green-50 hover:text-green-700"
                    }`}
                  >
                    {p.member.name}
                  </a>
                </li>
              );
            })
          }
        </ul>

        <div class="mt-6 px-3">
          <a
            href={`${import.meta.env.BASE_URL}${year}`}
            class="text-xs text-green-700 hover:underline"
          >
            ← Back to leaderboard
          </a>
        </div>
      </aside>

      <!-- Right column: player rounds -->
      <div class="flex-1 min-w-0">
        <PlayerRounds client:load player={player} courses={config.courses} />
      </div>
    </div>
  </main>
</Layout>
