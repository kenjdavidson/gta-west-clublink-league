---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import { Leaderboard } from "../../components/Leaderboard";
import { loadConfig, getConfiguredYears } from "../../utils/config-loader.js";
import { getYearlyScores } from "../../utils/score-service.js";

// ---------------------------------------------------------------------------
// Static paths — one path per configured season year
// ---------------------------------------------------------------------------

export async function getStaticPaths() {
  return getConfiguredYears().map((year) => ({ params: { year: String(year) } }));
}

// ---------------------------------------------------------------------------
// Page data
// ---------------------------------------------------------------------------

const { year } = Astro.params;
const allYears = getConfiguredYears();

const config = loadConfig(Number(year));

const scores = await getYearlyScores(Number(year), config);
---

<Layout title={`${config.league.name} – ${year}`} years={allYears} currentYear={Number(year)}>
  <Header years={allYears} currentYear={Number(year)} leagueName={config.league.name} />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Leaderboard client:load scores={scores} courses={config.courses} />
  </main>
</Layout>
