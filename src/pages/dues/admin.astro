---
import * as fs from "fs";
import * as path from "path";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import type { LeagueConfig } from "../../types/index.js";

const configPath = path.join(process.cwd(), "config", "league.json");
const config: LeagueConfig = JSON.parse(fs.readFileSync(configPath, "utf-8"));
const { year } = { year: String(config.league.currentYear) };
const githubRepo = config.league.githubRepo ?? "";

const members = config.members.map((m) => ({ name: m.name, paid: m.paid ?? false }));
---

<Layout title={`Dues Admin – ${config.league.name} ${year}`} years={[Number(year)]} currentYear={Number(year)}>
  <Header years={[Number(year)]} currentYear={Number(year)} leagueName={config.league.name} />

  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex-1">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-green-900 mb-2">Dues Admin</h1>
      <p class="text-gray-500 text-sm">
        {config.league.name} — {year} Season
      </p>
      <p class="text-yellow-700 bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-3 mt-4 text-sm">
        Check off members who have paid. When you click <strong>Submit</strong>, a pre-filled GitHub
        issue will open for the owner to review and apply the changes.
      </p>
    </div>

    <form id="admin-form" data-repo={githubRepo} class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-3">
      {members.map((member) => (
        <label class="flex items-center gap-3 cursor-pointer group">
          <input
            type="checkbox"
            name="paid"
            value={member.name}
            checked={member.paid}
            data-original={String(member.paid)}
            class="w-4 h-4 rounded border-gray-300 text-green-600 focus:ring-green-500 cursor-pointer"
          />
          <span class="text-sm text-gray-800 group-hover:text-green-800 transition-colors select-none">
            {member.name}
          </span>
          {member.paid && (
            <span class="text-xs text-green-600 font-medium">paid</span>
          )}
        </label>
      ))}

      <div class="pt-4 border-t border-gray-100">
        <button
          type="submit"
          class="w-full bg-green-800 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors text-sm"
        >
          Submit Payment Update →
        </button>
      </div>
    </form>

    <div class="mt-6">
      <a
        href={`${import.meta.env.BASE_URL}${year}/dues`}
        class="text-xs text-green-700 hover:underline"
      >
        ← Back to dues page
      </a>
    </div>

  </main>
</Layout>

<script>
  const REPO = document.getElementById("admin-form")!.dataset.repo!;
  const DATE_LOCALE = "en-CA";

  const form = document.getElementById("admin-form") as HTMLFormElement;

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    const checkboxes = form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');

    const nowPaid: string[] = [];
    const nowUnpaid: string[] = [];

    checkboxes.forEach((cb) => {
      const wasOriginallyPaid = cb.dataset.original === "true";
      const isNowChecked = cb.checked;
      if (!wasOriginallyPaid && isNowChecked) {
        nowPaid.push(cb.value);
      } else if (wasOriginallyPaid && !isNowChecked) {
        nowUnpaid.push(cb.value);
      }
    });

    if (nowPaid.length === 0 && nowUnpaid.length === 0) {
      alert("No changes detected. Please check or uncheck members before submitting.");
      return;
    }

    const lines: string[] = [];
    lines.push("## Payment Status Update\n");

    if (nowPaid.length > 0) {
      lines.push("### Newly Paid");
      nowPaid.forEach((name) => lines.push(`- ${name}`));
      lines.push("");
    }

    if (nowUnpaid.length > 0) {
      lines.push("### Marked as Unpaid");
      nowUnpaid.forEach((name) => lines.push(`- ${name}`));
      lines.push("");
    }

    const today = new Date().toLocaleDateString(DATE_LOCALE);
    lines.push(`_Submitted on ${today}_`);

    const title = encodeURIComponent(`Payment Update – ${today}`);
    const body = encodeURIComponent(lines.join("\n"));
    const labels = encodeURIComponent("dues");

    const url = `https://github.com/${REPO}/issues/new?title=${title}&body=${body}&labels=${labels}`;
    window.open(url, "_blank", "noopener,noreferrer");
  });
</script>
