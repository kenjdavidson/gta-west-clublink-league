---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  years?: number[];
  currentYear?: number;
}

const { title, years, currentYear } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="West GTA Clublink Men's Invitational Leaderboard" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col overflow-x-hidden">
    <slot />
    <Footer years={years} currentYear={currentYear} />
  </body>
</html>
