---
interface Props {
  years: number[];
  currentYear: number;
}

const { years, currentYear } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="bg-green-900 text-white shadow-lg border-b-4 border-yellow-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Left: Icon + Title -->
      <div class="flex items-center gap-3">
        <a href={base} class="flex items-center gap-3 group">
          <img
            src={`${base}logo.svg`}
            alt="GTA West Clublink League logo"
            class="h-10 w-10 object-contain"
            onerror="this.style.display='none'"
          />
          <span class="text-xl font-bold tracking-tight text-white group-hover:text-yellow-300 transition-colors">
            GTA West Clublink League
          </span>
        </a>
      </div>

      <!-- Right: Year selector -->
      {
        years.length > 1 && (
          <nav class="flex items-center gap-2" aria-label="Year navigation">
            {years.map((y) => (
              <a
                href={`${base}${y}`}
                class={`text-sm font-medium px-3 py-1.5 rounded-md transition-colors ${
                  y === currentYear
                    ? "bg-yellow-500 text-green-900 font-semibold"
                    : "text-green-200 hover:bg-green-700 hover:text-white"
                }`}
              >
                {y}
              </a>
            ))}
          </nav>
        )
      }
      {
        years.length === 1 && (
          <a href={`${base}${currentYear}`} class="text-sm font-medium text-yellow-400 hover:text-yellow-200 transition-colors">
            {currentYear}
          </a>
        )
      }
    </div>
  </div>
</header>

