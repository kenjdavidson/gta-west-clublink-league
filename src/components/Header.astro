---
interface Props {
  years: number[];
  currentYear: number;
}

const { years, currentYear } = Astro.props;
---

<header class="bg-green-800 text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Left: Icon + Title -->
      <div class="flex items-center gap-3">
        <img
          src="/logo.svg"
          alt="GTA West Clublink League logo"
          class="h-10 w-10 object-contain"
          onerror="this.style.display='none'"
        />
        <span class="text-xl font-bold tracking-tight">
          GTA West Clublink League
        </span>
      </div>

      <!-- Right: Year selector -->
      {
        years.length > 1 && (
          <form method="get" action="/" class="flex items-center gap-2">
            <label for="year-select" class="text-sm font-medium sr-only">
              Select Year
            </label>
            <select
              id="year-select"
              name="year"
              onchange="this.form.submit()"
              class="bg-green-700 border border-green-600 text-white text-sm rounded-md px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-white cursor-pointer"
            >
              {years.map((y) => (
                <option value={y} selected={y === currentYear}>
                  {y}
                </option>
              ))}
            </select>
          </form>
        )
      }
      {
        years.length === 1 && (
          <span class="text-sm font-medium">{currentYear}</span>
        )
      }
    </div>
  </div>
</header>
