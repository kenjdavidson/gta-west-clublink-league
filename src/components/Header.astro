---
interface Props {
  years: number[];
  currentYear: number;
  leagueName?: string;
}

const { years, currentYear, leagueName = "West GTA Clublink Men's Invitational" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="bg-green-900 text-white shadow-lg border-b-4 border-yellow-500">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Left: Icon + Title -->
      <div class="flex items-center gap-3">
        <a href={base} class="flex items-center gap-3 group">
          <img
            src={`${base}logo.png`}
            alt="West GTA Clublink Men's Invitational logo"
            class="h-12 w-12 object-contain"
            onerror={`this.src='${base}logo.svg';this.onerror=null`}
          />
          <span class="text-xl font-bold tracking-tight text-white group-hover:text-yellow-300 transition-colors">
            {leagueName}
          </span>
        </a>
      </div>

      <!-- Right: Navigation -->
      <nav class="flex items-center gap-2" aria-label="Site navigation">
        <a
          href={`${base}rules`}
          class="text-sm font-medium text-green-200 hover:bg-green-700 hover:text-white px-3 py-1.5 rounded-md transition-colors"
        >
          Rules
        </a>
        <a
          href={`${base}${currentYear}/dues`}
          class="text-sm font-medium text-green-200 hover:bg-green-700 hover:text-white px-3 py-1.5 rounded-md transition-colors"
        >
          Dues
        </a>
        {
          years.length > 1 && (
            years.map((y) => (
              <a
                href={`${base}${y}`}
                class={`text-sm font-medium px-3 py-1.5 rounded-md transition-colors ${
                  y === currentYear
                    ? "bg-yellow-500 text-green-900 font-semibold"
                    : "text-green-200 hover:bg-green-700 hover:text-white"
                }`}
              >
                {y}
              </a>
            ))
          )
        }
        {
          years.length === 1 && (
            <a href={`${base}${currentYear}`} class="text-sm font-medium text-yellow-400 hover:text-yellow-200 transition-colors px-3 py-1.5 rounded-md">
              {currentYear}
            </a>
          )
        }
      </nav>
    </div>
  </div>
</header>

